# Functional / E2E tests — local credentials.
# Copy to `.env.test.local` (gitignored) and fill in real values, OR
# put the same values in `tests/credentials.local.json`. Env vars take
# precedence over the JSON file.
#
# In CI, set these as repository / environment secrets — the
# Playwright config loads .env.test.local but does NOT require it,
# so empty file = "use process.env only".

# (Optional) base URL the tests run against. Defaults to
# http://localhost:3000 and Playwright auto-starts `npm run dev`.
# Set to a Vercel preview URL to run against a deployed env.
# TEST_BASE_URL=https://aaditri-emerland-staging.vercel.app

# ── Admin (signs in via /auth/admin-login — email only) ─────────────
TEST_ADMIN_IDENTIFIER=admin@example.com
TEST_ADMIN_PASSWORD=replace-me

# ── Approved resident (signs in via /auth/login — email or phone) ───
TEST_RESIDENT_IDENTIFIER=+919999900001
TEST_RESIDENT_PASSWORD=replace-me

# ── Pending (unapproved) resident — OPTIONAL ────────────────────────
# Skip if your test environment doesn't have an unapproved seed user;
# the resident-pending suite will skip cleanly.
# TEST_RESIDENT_PENDING_IDENTIFIER=+919999900002
# TEST_RESIDENT_PENDING_PASSWORD=replace-me

# ── Staff: security guard ───────────────────────────────────────────
TEST_STAFF_SECURITY_IDENTIFIER=+919999900003
TEST_STAFF_SECURITY_PASSWORD=replace-me

# ── Staff: housekeeping ─────────────────────────────────────────────
TEST_STAFF_HOUSEKEEPING_IDENTIFIER=+919999900004
TEST_STAFF_HOUSEKEEPING_PASSWORD=replace-me
