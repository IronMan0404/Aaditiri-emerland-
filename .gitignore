# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Original-source assets that live at the repo root for quick reference but
# are NOT what the app serves (the app uses /public/community.webp).
/community.png

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# …but the test env example IS committed as a template.
!.env.test.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright / functional tests
/test-results/
/playwright-report/
/playwright/.cache/
# Per-role storageState fixtures — regenerated by global-setup on every run
/tests/.auth/*.json
# Local-only test credentials. Use env vars (TEST_<ROLE>_*) in CI.
/tests/credentials.local.json
.env.test.local
